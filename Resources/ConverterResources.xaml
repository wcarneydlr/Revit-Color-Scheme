<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:ColorSchemeAddin.Views">

    <!-- Converter singletons — reference these in XAML as StaticResource -->
    <conv:ZeroToCollapsedConverter  x:Key="ZeroToCollapsedConverter"/>
    <conv:ZeroToVisibleConverter    x:Key="ZeroToVisibleConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:ByteStringConverter       x:Key="ByteStringConverter"/>
    <conv:InverseBoolConverter      x:Key="InverseBoolConverter"/>
    <conv:HexToBrushConverter       x:Key="HexToBrushConverter"/>
    <conv:NullToCollapsedConverter  x:Key="NullToCollapsedConverter"/>

</ResourceDictionary>
