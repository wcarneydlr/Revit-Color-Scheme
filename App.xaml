<Application x:Class="ColorSchemeAddin.WpfApp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ColorSchemeAddin.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DLRStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <views:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
            <views:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <views:ZeroToCollapsedConverter         x:Key="ZeroToCollapsed"/>
            <views:ZeroToVisibleConverter           x:Key="ZeroToVisible"/>
            <views:NullToCollapsedConverter         x:Key="NullToCollapsed"/>
            <views:ByteClampConverter               x:Key="ByteClamp"/>
            <BooleanToVisibilityConverter           x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
