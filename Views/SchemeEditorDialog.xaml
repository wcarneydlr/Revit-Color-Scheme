<Window x:Class="ColorSchemeAddin.Views.SchemeEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Color Scheme"
        Width="680" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1B222C"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="60"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource TitleBarPanel}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Edit: " Style="{StaticResource TitleBarText}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding Model.Name}" Style="{StaticResource TitleBarText}"/>
            </StackPanel>
        </Border>

        <!-- ── Entry list ─────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="24,16,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Column headers -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>   <!-- swatch -->
                    <ColumnDefinition Width="*"/>    <!-- value -->
                    <ColumnDefinition Width="80"/>   <!-- R -->
                    <ColumnDefinition Width="80"/>   <!-- G -->
                    <ColumnDefinition Width="80"/>   <!-- B -->
                    <ColumnDefinition Width="80"/>   <!-- hex -->
                    <ColumnDefinition Width="36"/>   <!-- pick -->
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Entry name" Style="{StaticResource H5}" Margin="4,0"/>
                <TextBlock Grid.Column="2" Text="R"   Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="G"   Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="B"   Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="Hex" Style="{StaticResource H5}" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Entry rows -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="Transparent" Padding="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Color swatch -->
                                    <Border Grid.Column="0" Style="{StaticResource ColorSwatch}"
                                            Background="{Binding PreviewBrush}"/>

                                    <!-- Value name -->
                                    <TextBox Grid.Column="1" Margin="4,0,8,0"
                                             Style="{StaticResource DLRTextBox}"
                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>

                                    <!-- R -->
                                    <TextBox Grid.Column="2" Margin="0,0,4,0"
                                             Style="{StaticResource DLRTextBox}"
                                             TextAlignment="Center"
                                             Text="{Binding R, UpdateSourceTrigger=PropertyChanged}"/>
                                    <!-- G -->
                                    <TextBox Grid.Column="3" Margin="0,0,4,0"
                                             Style="{StaticResource DLRTextBox}"
                                             TextAlignment="Center"
                                             Text="{Binding G, UpdateSourceTrigger=PropertyChanged}"/>
                                    <!-- B -->
                                    <TextBox Grid.Column="4" Margin="0,0,4,0"
                                             Style="{StaticResource DLRTextBox}"
                                             TextAlignment="Center"
                                             Text="{Binding B, UpdateSourceTrigger=PropertyChanged}"/>

                                    <!-- Hex (read-only) -->
                                    <TextBox Grid.Column="5" Margin="0,0,4,0"
                                             Style="{StaticResource DLRTextBox}"
                                             TextAlignment="Center"
                                             IsReadOnly="True"
                                             Text="{Binding HexColor, Mode=OneWay}"
                                             Foreground="{StaticResource TextMutedBrush}"/>

                                    <!-- Color picker button -->
                                    <Button Grid.Column="6"
                                            Width="28" Height="28"
                                            Style="{StaticResource IconButton}"
                                            Padding="0"
                                            Content="🎨"
                                            FontSize="14"
                                            ToolTip="Pick color"
                                            Click="PickColor_Click"
                                            Tag="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Add / remove row buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="+ Add entry" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="AddEntry_Click"/>
                <Button Content="Remove selected"
                        Style="{StaticResource SecondaryButton}"
                        Click="RemoveEntry_Click"/>
            </StackPanel>
        </Grid>

        <!-- ── Footer ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#FF1B222C"
                BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF"
                Padding="24,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="Cancel" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True"
                        Click="Cancel_Click"/>
                <Button Content="Save Changes"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="140"
                        IsDefault="True"
                        Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
