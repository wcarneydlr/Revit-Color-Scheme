<Window x:Class="ColorSchemeAddin.Views.SchemeEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Color Scheme"
        Width="720" Height="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1B222C"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- title bar with editable name -->
            <RowDefinition Height="*"/>    <!-- content -->
            <RowDefinition Height="56"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF1B222C"
                BorderThickness="0,0,0,1" BorderBrush="#22FFFFFF">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="24,0">
                <TextBlock Text="Edit: " Style="{StaticResource H2}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <!-- Name display mode -->
                <StackPanel x:Name="NameDisplayPanel"
                            Orientation="Horizontal" VerticalAlignment="Center"
                            Cursor="Hand"
                            MouseEnter="NameDisplay_MouseEnter"
                            MouseLeave="NameDisplay_MouseLeave">
                    <TextBlock x:Name="NameTextBlock"
                               Text="{Binding SchemeName}"
                               Style="{StaticResource H2}"
                               VerticalAlignment="Center"/>
                    <!-- Pencil icon — only visible on hover -->
                    <TextBlock x:Name="PencilIcon"
                               Text="✎"
                               FontSize="16"
                               Foreground="{StaticResource CTARedBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Opacity="0"
                               Cursor="Hand"
                               MouseLeftButtonUp="PencilIcon_Click"
                               ToolTip="Rename scheme"/>
                </StackPanel>

                <!-- Name edit mode (hidden by default) -->
                <StackPanel x:Name="NameEditPanel"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBox x:Name="NameEditBox"
                             Width="280" Height="32"
                             Padding="8,5"
                             VerticalContentAlignment="Center"
                             Background="{StaticResource InputBgBrush}"
                             Foreground="#FF1B222C"
                             BorderBrush="{StaticResource CTARedBrush}"
                             BorderThickness="1"
                             FontSize="15" FontWeight="SemiBold"
                             KeyDown="NameEditBox_KeyDown"
                             LostFocus="NameEditBox_LostFocus"/>
                    <Button Content="✓" Width="32" Height="32"
                            Margin="6,0,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Padding="0"
                            Click="ConfirmRename_Click"
                            ToolTip="Confirm rename"/>
                    <Button Content="✕" Width="32" Height="32"
                            Margin="4,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Padding="0"
                            Click="CancelRename_Click"
                            ToolTip="Cancel"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Content ───────────────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Edit Options — always fully visible -->
                <RowDefinition Height="Auto"/>  <!-- separator -->
                <RowDefinition Height="Auto"/>  <!-- Edit Values header + col headers -->
                <RowDefinition Height="*"/>     <!-- scrolling entries — takes remaining space -->
                <RowDefinition Height="Auto"/>  <!-- add entry (fixed) -->
            </Grid.RowDefinitions>

            <!-- ── Edit Options (top, always fully visible) ─────────── -->
                <StackPanel Margin="24,16,24,8">
                    <TextBlock Text="Edit Options" Style="{StaticResource H3}"
                               Margin="0,0,0,12"/>

                    <!-- Fill parameter -->
                    <TextBlock Text="Fill parameter" Style="{StaticResource H5}"
                               Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Margin="0,0,8,0"
                                  Style="{StaticResource DLRComboBox}"
                                  ItemsSource="{Binding AvailableParameters}"
                                  SelectedItem="{Binding ParameterName}"/>
                        <Button Grid.Column="1" Content="+ New parameter"
                                Style="{StaticResource SecondaryButton}"
                                Click="ShowNewParam_Click"
                                Visibility="{Binding ShowParamInput,
                                    Converter={StaticResource InverseBoolToVisibility}}"/>
                    </Grid>

                    <!-- Inline new parameter creator -->
                    <Border Background="#1AFFFFFF" CornerRadius="6"
                            Padding="12" Margin="0,0,0,12"
                            Visibility="{Binding ShowParamInput,
                                Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Height="32" Padding="10,5"
                                     VerticalContentAlignment="Center"
                                     Background="{StaticResource InputBgBrush}"
                                     Foreground="#FF1B222C"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Text="{Binding NewParameterName,
                                         UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Create"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,0" MinWidth="80"
                                    Click="CreateNewParam_Click"/>
                            <Button Grid.Column="2" Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="CancelNewParam_Click"/>
                        </Grid>
                    </Border>

                    <!-- Applies to -->
                    <TextBlock Text="Applies to" Style="{StaticResource H5}"
                               Margin="0,4,0,8"/>
                    <WrapPanel Margin="0,0,0,8">
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Rooms" Margin="0,0,20,4"
                                  IsChecked="{Binding ApplyRooms}"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Areas" Margin="0,0,20,4"
                                  IsChecked="{Binding ApplyAreas}"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Masses" Margin="0,0,20,4"
                                  IsChecked="{Binding ApplyMasses}"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Generic Models" Margin="0,0,20,4"
                                  IsChecked="{Binding ApplyGenericModels}"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Floors" Margin="0,0,20,4"
                                  IsChecked="{Binding ApplyFloors}"/>
                    </WrapPanel>

                    <!-- Area scheme picker -->
                    <Border Background="#1AFFFFFF" CornerRadius="6"
                            Padding="12" Margin="0,0,0,4"
                            Visibility="{Binding ApplyAreas,
                                Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Area scheme" Style="{StaticResource H5}"
                                       Margin="0,0,0,6"/>
                            <RadioButton Style="{StaticResource DLRRadioButton}"
                                         Content="Use existing area scheme:"
                                         GroupName="EditAreaScheme"
                                         IsChecked="{Binding CreateNewAreaScheme,
                                             Converter={StaticResource InverseBool}}"
                                         Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource DLRComboBox}"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding AvailableAreaSchemes}"
                                      SelectedItem="{Binding SelectedAreaScheme}"
                                      DisplayMemberPath="Name"
                                      IsEnabled="{Binding CreateNewAreaScheme,
                                          Converter={StaticResource InverseBool}}"/>
                            <RadioButton Style="{StaticResource DLRRadioButton}"
                                         Content="Create / use 'Color Schemes' area scheme"
                                         GroupName="EditAreaScheme"
                                         IsChecked="{Binding CreateNewAreaScheme}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            <!-- Separator -->
            <Separator Grid.Row="1" Background="#33FFFFFF" Height="1" Margin="24,4"/>

            <!-- ── Edit Values header + column headers (fixed) ───────── -->
            <StackPanel Grid.Row="2" Margin="24,8,24,4">
                <TextBlock Text="Edit Values" Style="{StaticResource H3}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="36"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Entry name"
                               Style="{StaticResource H5}" Margin="4,0"/>
                    <TextBlock Grid.Column="2" Text="R"
                               Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="G"
                               Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="B"
                               Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- Scrolling entry rows only -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          Margin="24,0,24,0">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="22" Height="22"
                                        CornerRadius="4"
                                        Background="{Binding PreviewBrush}"
                                        BorderThickness="0.5"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        VerticalAlignment="Center"
                                        Cursor="Hand" ToolTip="Click to pick color"
                                        MouseLeftButtonUp="ColorSwatch_Click"
                                        Tag="{Binding}"/>
                                <TextBox Grid.Column="1" Margin="4,0,6,0"
                                         Height="32" Padding="8,5"
                                         VerticalContentAlignment="Center"
                                         Background="{StaticResource InputBgBrush}"
                                         Foreground="#FF1B222C"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1"
                                         Text="{Binding Value,
                                             UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Margin="0,0,4,0"
                                         Height="32" Padding="4,5"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Background="{StaticResource InputBgBrush}"
                                         Foreground="#FF1B222C"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1"
                                         Text="{Binding R, UpdateSourceTrigger=PropertyChanged,
                                             Converter={StaticResource ByteClamp}}"/>
                                <TextBox Grid.Column="3" Margin="0,0,4,0"
                                         Height="32" Padding="4,5"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Background="{StaticResource InputBgBrush}"
                                         Foreground="#FF1B222C"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1"
                                         Text="{Binding G, UpdateSourceTrigger=PropertyChanged,
                                             Converter={StaticResource ByteClamp}}"/>
                                <TextBox Grid.Column="4" Margin="0,0,4,0"
                                         Height="32" Padding="4,5"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Background="{StaticResource InputBgBrush}"
                                         Foreground="#FF1B222C"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1"
                                         Text="{Binding B, UpdateSourceTrigger=PropertyChanged,
                                             Converter={StaticResource ByteClamp}}"/>
                                <Button Grid.Column="5" Content="✕"
                                        Style="{StaticResource IconButton}"
                                        Padding="0" Width="28"
                                        Click="DeleteEntry_Click"
                                        Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Fixed Add entry button -->
            <Border Grid.Row="4" Padding="24,8"
                    BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF">
                <Button Content="+ Add entry"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left"
                        Click="AddEntry_Click"/>
            </Border>
        </Grid>

        <!-- ── Footer ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#FF1B222C"
                BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF"
                Padding="24,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="Cancel" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        IsCancel="True" Click="Cancel_Click"/>
                <Button Content="Save Changes" MinWidth="140"
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
