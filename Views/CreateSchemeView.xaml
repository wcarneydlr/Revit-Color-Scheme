<UserControl x:Class="ColorSchemeAddin.Views.CreateSchemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF283342">
    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="36,24,36,24" MaxWidth="860">

            <!-- Card 1: Upload Excel -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Upload Excel" Style="{StaticResource H2}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,14"
                               Text="Import a populated template to create one or more schemes. Each sheet becomes a separate scheme."/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,8,0"
                                 Style="{StaticResource DLRTextBox}"
                                 Text="{Binding ImportFilePath, Mode=OneWay}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="Browse…" Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseImportFileCommand}"/>
                        <Button Grid.Column="2" Content="Download template"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding DownloadTemplateCommand}"/>
                    </Grid>
                    <ListBox ItemsSource="{Binding ImportedSchemes}"
                             SelectedItem="{Binding SelectedImportedScheme}"
                             Background="#1AFFFFFF" BorderThickness="0" MaxHeight="110"
                             Visibility="{Binding ImportedSchemes.Count,
                                 Converter={StaticResource ZeroToCollapsed}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,3">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource H4Bold}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource MutedText}"
                                               VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Run Text="{Binding Entries.Count, Mode=OneWay}"/>
                                        <Run Text=" entries"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Upload and Create"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" MinWidth="180"
                            Margin="0,12,0,0"
                            Command="{Binding CreateFromImportCommand}"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Create from scratch -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Create from scratch" Style="{StaticResource H2}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,14"
                               Text="Start with a blank scheme and define your colors and values manually."/>
                    <TextBlock Text="Scheme name" Style="{StaticResource H5}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DLRTextBox}" Margin="0,0,0,12"
                             Text="{Binding ScratchSchemeName,
                                 UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Entry list header -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Entry name"
                                   Style="{StaticResource H5}" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="R"
                                   Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="G"
                                   Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="B"
                                   Style="{StaticResource H5}" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Entry rows -->
                    <ItemsControl ItemsSource="{Binding ScratchScheme.Entries}" MaxHeight="220">
                        <ItemsControl.Template>
                            <ControlTemplate>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource ColorSwatch}"
                                            Background="{Binding PreviewBrush}"
                                            VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Margin="4,0,6,0"
                                             Style="{StaticResource DLRTextBox}"
                                             Text="{Binding Value,
                                                 UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="2" Margin="0,0,4,0"
                                             Style="{StaticResource DLRTextBox}"
                                             TextAlignment="Center"
                                             Text="{Binding R,
                                                 UpdateSourceTrigger=PropertyChanged,
                                                 Converter={StaticResource ByteClamp}}"/>
                                    <TextBox Grid.Column="3" Margin="0,0,4,0"
                                             Style="{StaticResource DLRTextBox}"
                                             TextAlignment="Center"
                                             Text="{Binding G,
                                                 UpdateSourceTrigger=PropertyChanged,
                                                 Converter={StaticResource ByteClamp}}"/>
                                    <TextBox Grid.Column="4" Margin="0,0,4,0"
                                             Style="{StaticResource DLRTextBox}"
                                             TextAlignment="Center"
                                             Text="{Binding B,
                                                 UpdateSourceTrigger=PropertyChanged,
                                                 Converter={StaticResource ByteClamp}}"/>
                                    <Button Grid.Column="5" Content="✕"
                                            Style="{StaticResource IconButton}"
                                            Padding="0" Width="28"
                                            Command="{Binding DataContext.RemoveScratchEntryCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="+ Add entry" Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddScratchEntryCommand}"/>
                        <Button Content="Create New Scheme"
                                Style="{StaticResource PrimaryButton}" MinWidth="180"
                                Command="{Binding CreateFromScratchCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Card 3: From existing Revit scheme -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="From existing scheme" Style="{StaticResource H2}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,14"
                               Text="Select an existing Revit Color Fill scheme to use as a base."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Margin="0,0,8,0"
                                  Style="{StaticResource DLRComboBox}"
                                  ItemsSource="{Binding ExistingRevitSchemes}"
                                  SelectedItem="{Binding SelectedRevitScheme}"
                                  DisplayMemberPath="Name"/>
                        <Button Grid.Column="1" Content="Load scheme"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ImportFromRevitSchemeCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Shared settings -->
            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fill parameter" Style="{StaticResource H5}"
                                   Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource DLRComboBox}"
                                  ItemsSource="{Binding AvailableParameters}"
                                  SelectedItem="{Binding ParameterName}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Apply to" Style="{StaticResource H5}"
                                   Margin="0,0,0,8"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Rooms" IsChecked="{Binding TargetRooms}"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Areas" IsChecked="{Binding TargetAreas}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="{Binding LastResult}"
                       Style="{StaticResource MutedText}"
                       Margin="0,0,0,24"
                       Visibility="{Binding LastResult,
                           Converter={StaticResource NullToCollapsed}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
