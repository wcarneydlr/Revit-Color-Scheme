<UserControl x:Class="ColorSchemeAddin.Views.CreateSchemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF283342">

    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="36,24,36,24" MaxWidth="900">

            <!-- ── Section: Import from Excel ─────────────────────────── -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Import from Excel" Style="{StaticResource H2}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,16"
                               Text="Upload a populated Excel template to create one or more color schemes. Each sheet in the workbook becomes a separate scheme."/>

                    <!-- File picker row -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,8,0"
                                 Style="{StaticResource DLRTextBox}"
                                 Text="{Binding ImportFilePath, Mode=OneWay}"
                                 IsReadOnly="True"
                                 PlaceholderText="No file selected…"/>
                        <Button Grid.Column="1" Content="Browse…" Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseImportFileCommand}"/>
                        <Button Grid.Column="2" Content="Download Template"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding DownloadTemplateCommand}"
                                ToolTip="Download a blank Excel template to fill in"/>
                    </Grid>

                    <!-- Imported schemes preview -->
                    <TextBlock Text="Schemes found in file:" Style="{StaticResource H5}"
                               Margin="0,0,0,6"
                               Visibility="{Binding ImportedSchemes.Count, Converter={x:Static ZeroToCollapsedConverter}}"/>
                    <ListBox ItemsSource="{Binding ImportedSchemes}"
                             SelectedItem="{Binding SelectedImportedScheme}"
                             Background="#22FFFFFF"
                             BorderThickness="0"
                             MaxHeight="120"
                             Visibility="{Binding ImportedSchemes.Count, Converter={x:Static ZeroToCollapsedConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,4">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource H4Bold}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" · " Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource MutedText}" VerticalAlignment="Center">
                                        <Run Text="{Binding Entries.Count, Mode=OneWay}"/><Run Text=" entries"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ── Section: Import from existing Revit scheme ─────────── -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Copy from existing Revit scheme" Style="{StaticResource H2}"/>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,16"
                               Text="Select an existing Color Fill Scheme from this document to use as a starting point."/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Margin="0,0,8,0"
                                  Style="{StaticResource DLRComboBox}"
                                  ItemsSource="{Binding ExistingRevitSchemes}"
                                  SelectedItem="{Binding SelectedRevitScheme}"
                                  DisplayMemberPath="Name"
                                  PlaceholderText="Select a Revit color scheme…"/>
                        <Button Grid.Column="1" Content="Load scheme"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ImportFromRevitSchemeCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Section: Scheme settings ───────────────────────────── -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Scheme settings" Style="{StaticResource H2}"/>

                    <!-- Parameter -->
                    <TextBlock Text="Color fill parameter" Style="{StaticResource H5}" Margin="0,0,0,6"/>
                    <ComboBox Style="{StaticResource DLRComboBox}"
                              ItemsSource="{Binding AvailableParameters}"
                              SelectedItem="{Binding ParameterName}"
                              Margin="0,0,0,16"/>

                    <!-- Target category -->
                    <TextBlock Text="Apply to" Style="{StaticResource H5}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Rooms"
                                  IsChecked="{Binding TargetRooms}"
                                  Margin="0,0,20,0"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Areas"
                                  IsChecked="{Binding TargetAreas}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Create button + result ──────────────────────────────── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <TextBlock Text="{Binding LastResult}" Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="Create Scheme"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="160"
                        Command="{Binding CreateFromImportCommand}"
                        ToolTip="Create the selected scheme in the Revit document"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
