<Window x:Class="ColorSchemeAddin.Views.MainDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ColorSchemeAddin.ViewModels"
        xmlns:views="clr-namespace:ColorSchemeAddin.Views"
        Title="DLR Color Scheme Manager"
        Width="1100" Height="740"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FF1B222C">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Tab headers -->
            <RowDefinition Height="*"/>    <!-- Tab content -->
            <RowDefinition Height="36"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource TitleBarPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="DLR" FontFamily="{StaticResource DisplayFont}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource CTARedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="GROUP" FontFamily="{StaticResource DisplayFont}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <Rectangle Width="1" Height="20" Fill="#44FFFFFF" Margin="16,0"/>
                    <TextBlock Text="Color Scheme Manager"
                               Style="{StaticResource TitleBarText}"/>
                </StackPanel>

                <!-- Doc info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DocumentTitle}"
                               Style="{StaticResource H5}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text=" · " Style="{StaticResource H5}"/>
                    <TextBlock Text="{Binding RevitVersion}"
                               Style="{StaticResource H5}"/>
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="2" Content="✕"
                        Width="32" Height="32"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0"
                        Click="CloseButton_Click"
                        VerticalAlignment="Center"
                        ToolTip="Close"/>
            </Grid>
        </Border>

        <!-- ── Tab headers ────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#FF1B222C"
                BorderThickness="0,0,0,1" BorderBrush="#22FFFFFF">
            <TabControl x:Name="MainTabControl"
                        Style="{StaticResource DLRTabControl}"
                        SelectedIndex="{Binding SelectedTabIndex}"
                        Background="Transparent">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <TabPanel DockPanel.Dock="Top" IsItemsHost="True"
                                      Background="Transparent" Margin="36,0,0,0"/>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </DockPanel>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- Tab 1: Create -->
                <TabItem Header="  Create Scheme  " Style="{StaticResource DLRTabItem}">
                    <views:CreateSchemeView DataContext="{Binding CreateVM}"/>
                </TabItem>

                <!-- Tab 2: Manage -->
                <TabItem Header="  Manage  " Style="{StaticResource DLRTabItem}">
                    <views:ManageSchemeView DataContext="{Binding ManageVM}"/>
                </TabItem>

                <!-- Tab 3: Apply -->
                <TabItem Header="  Apply  " Style="{StaticResource DLRTabItem}">
                    <views:ApplySchemeView DataContext="{Binding ApplyVM}"/>
                </TabItem>
            </TabControl>
        </Border>

        <!-- ── Tab content area ───────────────────────────────────── -->
        <!-- Content is rendered inside each TabItem above -->
        <Grid Grid.Row="2"/>

        <!-- ── Status bar ─────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#FF1B222C"
                BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF"
                Padding="36,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource StatusLabel}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <ProgressBar Width="80" Height="4"
                                 IsIndeterminate="{Binding IsBusy}"
                                 Visibility="{Binding IsBusy, Converter={x:Static BooleanToVisibilityConverter}}"
                                 Background="#22FFFFFF"
                                 Foreground="{StaticResource CTARedBrush}"
                                 BorderThickness="0"/>
                    <TextBlock Text="v1.0.0" Style="{StaticResource StatusLabel}"
                               Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
