<Window x:Class="ColorSchemeAddin.Views.MainDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ColorSchemeAddin.Views"
        Title="DLR Color Scheme Manager"
        Width="1100" Height="740"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FF1B222C">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ── Nav bar ───────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF1B222C"
                BorderThickness="0,0,0,1" BorderBrush="#22FFFFFF">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="DLR"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource CTARedBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="GROUP"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="3,0,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Height="20"
                           Fill="#44FFFFFF" Margin="16,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Create"
                            Click="NavCreate_Click"
                            Height="56" Padding="20,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FFB0B8C4"
                            FontSize="14"
                            Cursor="Hand"/>
                    <Button Content="Manage"
                            Click="NavManage_Click"
                            Height="56" Padding="20,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FFB0B8C4"
                            FontSize="14"
                            Cursor="Hand"/>
                    <Button Content="Apply"
                            Click="NavApply_Click"
                            Height="56" Padding="20,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FFB0B8C4"
                            FontSize="14"
                            Cursor="Hand"/>
                </StackPanel>

                <TextBlock Grid.Column="3"
                           Style="{StaticResource H5}"
                           VerticalAlignment="Center" Margin="0,0,16,0">
                    <Run Text="{Binding DocumentTitle, Mode=OneWay}"/>
                    <Run Text=" · "/>
                    <Run Text="{Binding RevitVersion, Mode=OneWay}"/>
                </TextBlock>

                <Button Grid.Column="4" Content="✕"
                        Width="32" Height="32"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- ── Tab content — use ContentControl, swap in code-behind ── -->
        <ContentControl x:Name="MainContent" Grid.Row="1"/>

        <!-- ── Status bar ────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#FF1B222C"
                BorderThickness="0,1,0,0" BorderBrush="#22FFFFFF"
                Padding="24,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource StatusLabel}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ProgressBar Width="80" Height="3" Margin="0,0,10,0"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsBusy,
                                     Converter={StaticResource BoolToVisibility}}"
                                 Background="#22FFFFFF"
                                 Foreground="{StaticResource CTARedBrush}"
                                 BorderThickness="0"/>
                    <TextBlock Text="v1.0.0" Style="{StaticResource StatusLabel}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
