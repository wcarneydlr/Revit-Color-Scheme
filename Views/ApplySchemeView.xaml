<UserControl x:Class="ColorSchemeAddin.Views.ApplySchemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF283342">

    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="36,24,36,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left column ───────────────────────────────────── -->
            <StackPanel Grid.Column="0">

                <!-- Scheme selector -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Select Scheme" Style="{StaticResource H2}"/>
                        <ComboBox Style="{StaticResource DLRComboBox}"
                                  Margin="0,8,0,0"
                                  ItemsSource="{Binding AvailableSchemes}"
                                  SelectedItem="{Binding SelectedScheme}"
                                  DisplayMemberPath="Name"/>
                        <Button Content="⟳  Refresh list" Margin="0,8,0,0"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left"
                                Command="{Binding RefreshSchemesCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Color fill scheme -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Room / Area Color Fill" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,12"
                                   Text="Apply the color fill scheme directly to Revit views."/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Apply to floor plan views"
                                  IsChecked="{Binding ApplyToFloorPlans}"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Apply to area plan views"
                                  IsChecked="{Binding ApplyToAreaPlans}"/>
                        <Button Content="Apply color fill scheme"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                MinWidth="200"
                                Margin="0,12,0,0"
                                Command="{Binding ApplyColorFillSchemeCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Materials -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Create Materials" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,12"
                                   Text="Creates solid-color materials for each entry. Duplicates from 'Color Scheme' material if present, otherwise creates new materials. Naming: [Scheme] - [Entry]."/>
                        <Button Content="Create / update materials"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                MinWidth="200"
                                Command="{Binding CreateMaterialsCommandCommand}"/>
                    </StackPanel>
                </Border>

                <!-- View filters -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="View Filters" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,12"
                                   Text="Creates parameter filters with solid color graphic overrides for each scheme entry."/>
                        <Button Content="Create view filters"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                MinWidth="200"
                                Margin="0,0,0,8"
                                Command="{Binding CreateViewFiltersCommandCommand}"/>
                        <Button Content="Apply to active view (temporary)"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left"
                                MinWidth="200"
                                Command="{Binding ApplyTemporaryViewCommand}"
                                ToolTip="Applies filters to the currently active view as temporary view properties"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Right column ───────────────────────────────────── -->
            <StackPanel Grid.Column="2">

                <!-- View template generator -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Generate View Templates" Style="{StaticResource H2}"/>
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,16"
                                   Text="Creates view templates for selected schemes. Choose view types and color application method."/>

                        <!-- View types -->
                        <TextBlock Text="View types" Style="{StaticResource H5}" Margin="0,0,0,6"/>
                        <WrapPanel>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Floor Plan" Margin="0,0,16,0"
                                      IsChecked="{Binding VtFloorPlan}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Area Plan" Margin="0,0,16,0"
                                      IsChecked="{Binding VtAreaPlan}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="3D" Margin="0,0,16,0"
                                      IsChecked="{Binding VtThreeD}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Section"
                                      IsChecked="{Binding VtSection}"/>
                        </WrapPanel>

                        <Separator Style="{StaticResource DLRSeparator}"/>

                        <!-- Application method -->
                        <TextBlock Text="Color application method" Style="{StaticResource H5}" Margin="0,0,0,6"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="Color fill scheme (rooms / areas)"
                                  IsChecked="{Binding VtUseColorFill}"/>
                        <CheckBox Style="{StaticResource DLRCheckBox}"
                                  Content="View filters (graphic overrides)"
                                  IsChecked="{Binding VtUseFilters}"/>

                        <Separator Style="{StaticResource DLRSeparator}"/>

                        <!-- Scheme selection for batch -->
                        <TextBlock Text="Select schemes to generate templates for"
                                   Style="{StaticResource H5}" Margin="0,0,0,6"/>
                        <Border Background="#22FFFFFF" CornerRadius="4" MaxHeight="180"
                                Padding="0" Margin="0,0,0,16">
                            <DataGrid Style="{StaticResource DLRDataGrid}"
                                      ItemsSource="{Binding BatchSchemeRows}"
                                      MaxHeight="180"
                                      ColumnHeaderStyle="{StaticResource DLRDataGridColumnHeader}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="36">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource DLRCheckBox}"
                                                          HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Scheme" Width="*"
                                                        Binding="{Binding Name}"
                                                        ElementStyle="{StaticResource H4}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Button Content="Generate view templates"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left"
                                MinWidth="220"
                                Command="{Binding GenerateViewTemplatesCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Result -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Last operation" Style="{StaticResource H5}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding LastResult}"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
