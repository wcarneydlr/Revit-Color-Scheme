<UserControl x:Class="ColorSchemeAddin.Views.ApplySchemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF283342">
    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
    </UserControl.Resources>

    <Grid>
        <!-- Step 1: Select method -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsOnStep1,
                          Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="36,24,36,24" MaxWidth="640">
                <TextBlock Text="How would you like to apply the scheme?"
                           Style="{StaticResource H2}" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,24"
                           Text="Choose one method then click Next to select the scheme and configure details."/>

                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <StackPanel>
                        <RadioButton Style="{StaticResource MethodRadioStyle}"
                                     Content="Create Materials"
                                     Tag="Creates solid-color materials for each scheme entry."
                                     IsChecked="{Binding SelectedMethod,
                                         Converter={StaticResource EnumEqualConverter},
                                         ConverterParameter=CreateMaterials}"/>
                        <Separator Background="#22FFFFFF" Height="1" Margin="0"/>
                        <RadioButton Style="{StaticResource MethodRadioStyle}"
                                     Content="Apply to current view"
                                     Tag="Apply to the active view — temporary or permanent."
                                     IsChecked="{Binding SelectedMethod,
                                         Converter={StaticResource EnumEqualConverter},
                                         ConverterParameter=ApplyToCurrentView}"/>
                        <Separator Background="#22FFFFFF" Height="1" Margin="0"/>
                        <RadioButton Style="{StaticResource MethodRadioStyle}"
                                     Content="Apply to selected views"
                                     Tag="Pick specific views from the document."
                                     IsChecked="{Binding SelectedMethod,
                                         Converter={StaticResource EnumEqualConverter},
                                         ConverterParameter=ApplyToSelectedViews}"/>
                        <Separator Background="#22FFFFFF" Height="1" Margin="0"/>
                        <RadioButton Style="{StaticResource MethodRadioStyle}"
                                     Content="Apply to view templates"
                                     Tag="Apply filter overrides to existing view templates."
                                     IsChecked="{Binding SelectedMethod,
                                         Converter={StaticResource EnumEqualConverter},
                                         ConverterParameter=ApplyToViewTemplates}"/>
                        <Separator Background="#22FFFFFF" Height="1" Margin="0"/>
                        <RadioButton Style="{StaticResource MethodRadioStyle}"
                                     Content="Generate view templates"
                                     Tag="Create new view templates across Floor Plan, Area Plan, 3D, Section."
                                     IsChecked="{Binding SelectedMethod,
                                         Converter={StaticResource EnumEqualConverter},
                                         ConverterParameter=GenerateViewTemplates}"/>
                    </StackPanel>
                </Border>

                <Button Content="Next →"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right"
                        MinWidth="120" Margin="0,16,0,0"
                        Command="{Binding NextCommand}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Step 2: Configure + Apply -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsOnStep1,
                          Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel Margin="36,24,36,24" MaxWidth="780">

                <!-- Back + heading -->
                <Grid Margin="0,0,0,20">
                    <Button Content="← Back" HorizontalAlignment="Left"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BackCommand}"/>
                    <TextBlock Text="{Binding SelectedMethod}"
                               Style="{StaticResource H2}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Scheme selector -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Select scheme" Style="{StaticResource H5}"
                                   Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource DLRComboBox}"
                                  ItemsSource="{Binding AvailableSchemes}"
                                  SelectedItem="{Binding SelectedScheme}"
                                  DisplayMemberPath="Name"/>
                    </StackPanel>
                </Border>

                <!-- Active view options -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding SelectedMethod,
                            Converter={StaticResource EnumEqualConverter},
                            ConverterParameter=ApplyToCurrentView}">
                    <StackPanel>
                        <TextBlock Text="Application method" Style="{StaticResource H5}"
                                   Margin="0,0,0,10"/>
                        <RadioButton Style="{StaticResource DLRRadioButton}"
                                     Content="Temporary — reverts when view is closed"
                                     IsChecked="{Binding ApplyTemporary}"
                                     GroupName="ViewMode"/>
                        <RadioButton Style="{StaticResource DLRRadioButton}"
                                     Content="Permanent — saved with the document"
                                     IsChecked="{Binding ApplyPermanent}"
                                     GroupName="ViewMode" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Selected views -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding SelectedMethod,
                            Converter={StaticResource EnumEqualConverter},
                            ConverterParameter=ApplyToSelectedViews}">
                    <StackPanel>
                        <TextBlock Text="Select views" Style="{StaticResource H5}"
                                   Margin="0,0,0,8"/>
                        <Border Background="#1AFFFFFF" CornerRadius="4" MaxHeight="200">
                            <DataGrid Style="{StaticResource DLRDataGrid}"
                                      ItemsSource="{Binding SelectableViews}"
                                      ColumnHeaderStyle="{StaticResource DLRDataGridColumnHeader}"
                                      MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="36">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected,
                                                              UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource DLRCheckBox}"
                                                          HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="View name" Width="*"
                                                        Binding="{Binding ViewName}"
                                                        ElementStyle="{StaticResource H4}"/>
                                    <DataGridTextColumn Header="Type" Width="120"
                                                        Binding="{Binding ViewType}"
                                                        ElementStyle="{StaticResource H4}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Margin="0,0,20,0"
                                      Content="Remove existing view templates"
                                      IsChecked="{Binding RemoveExistingTemplates}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Update existing view templates"
                                      IsChecked="{Binding UpdateExistingTemplates}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Generate view templates options -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding SelectedMethod,
                            Converter={StaticResource EnumEqualConverter},
                            ConverterParameter=GenerateViewTemplates}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="View types" Style="{StaticResource H5}"
                                       Margin="0,0,0,8"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Floor Plan" IsChecked="{Binding VtFloorPlan}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Area Plan"  IsChecked="{Binding VtAreaPlan}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="3D"         IsChecked="{Binding VtThreeD}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Section"    IsChecked="{Binding VtSection}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Color method" Style="{StaticResource H5}"
                                       Margin="0,0,0,8"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="Color fill scheme"
                                      IsChecked="{Binding VtUseColorFill}"/>
                            <CheckBox Style="{StaticResource DLRCheckBox}"
                                      Content="View filters"
                                      IsChecked="{Binding VtUseFilters}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Apply + result -->
                <Grid Margin="0,4,0,0">
                    <Button Content="Apply Scheme"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" MinWidth="160"
                            Command="{Binding ApplySchemeCommand}"/>
                    <TextBlock Text="{Binding LastResult}"
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               MaxWidth="400" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
