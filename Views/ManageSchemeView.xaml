<UserControl x:Class="ColorSchemeAddin.Views.ManageSchemeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF283342">
    <UserControl.Resources>
        <ResourceDictionary Source="../Resources/DLRStyles.xaml"/>
    </UserControl.Resources>

    <Grid Margin="36,24,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Color Schemes" Style="{StaticResource H2}"/>
                <TextBlock Text=" — scanning…"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           Visibility="{Binding IsScanning,
                               Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="⟳  Refresh" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshSchemesCommand}"/>
                <Button Content="Export selected" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportSelectedCommand}"/>
                <Button Content="Export all" Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ExportAllCommand}"/>
                <Button Content="+ Add New Scheme"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding AddNewSchemeCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Scheme grid -->
        <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True">
            <DataGrid Style="{StaticResource DLRDataGrid}"
                      ItemsSource="{Binding SchemeRows}"
                      SelectedItem="{Binding SelectedRow}"
                      ColumnHeaderStyle="{StaticResource DLRDataGridColumnHeader}"
                      EnableColumnVirtualization="False">
                <DataGrid.Columns>

                    <!-- Checkbox -->
                    <DataGridTemplateColumn Width="36" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected,
                                              UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource DLRCheckBox}"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Scheme name -->
                    <DataGridTemplateColumn Header="Scheme name" Width="*" MinWidth="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Background="Transparent" BorderThickness="0"
                                        HorizontalAlignment="Left" Padding="8,0"
                                        Command="{Binding DataContext.EditSchemeCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="{StaticResource BodyFont}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource CTARedBrush}"
                                                       TextDecorations="Underline"
                                                       Cursor="Hand" Padding="8,0"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Models -->
                    <DataGridTemplateColumn Header="Gen.
Models" Width="76">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Style="{StaticResource H4}"
                                           Text="{Binding HasGenericModels,
                                               Converter={StaticResource BoolToCheckmark}}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Rooms — green if applied -->
                    <DataGridTemplateColumn Header="Rooms" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="{Binding HasRooms,
                                               Converter={StaticResource BoolToCheckmark}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource H4}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRoomsApplied}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="#FF2D9E4A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Areas — green if applied -->
                    <DataGridTemplateColumn Header="Areas" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="{Binding HasAreas,
                                               Converter={StaticResource BoolToCheckmark}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource H4}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAreasApplied}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="#FF2D9E4A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Floors -->
                    <DataGridTemplateColumn Header="Floors" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Style="{StaticResource H4}"
                                           Text="{Binding HasFloors,
                                               Converter={StaticResource BoolToCheckmark}}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Materials -->
                    <DataGridTemplateColumn Header="Materials" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Style="{StaticResource H4}"
                                           Text="{Binding HasMaterials,
                                               Converter={StaticResource BoolToCheckmark}}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 3D — green if applied -->
                    <DataGridTemplateColumn Header="3D" Width="44">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="{Binding Has3D,
                                               Converter={StaticResource BoolToCheckmark}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource H4}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Is3DApplied}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="#FF2D9E4A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Floor Plan — green if applied -->
                    <DataGridTemplateColumn Header="Floor&#10;Plan" Width="82">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="{Binding HasFloorPlan,
                                               Converter={StaticResource BoolToCheckmark}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource H4}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFloorPlanApplied}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="#FF2D9E4A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Area Plan — green if applied -->
                    <DataGridTemplateColumn Header="Area&#10;Plan" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center"
                                           Text="{Binding HasAreaPlan,
                                               Converter={StaticResource BoolToCheckmark}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource H4}">
                                            <Setter Property="Foreground"
                                                    Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAreaPlanApplied}"
                                                             Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="#FF2D9E4A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status badge -->
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2"
                                        HorizontalAlignment="Left" Margin="8,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsApplied}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#1A2D9E4A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsApplied}"
                                                             Value="False">
                                                    <Setter Property="Background"
                                                            Value="#22FFFFFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock HorizontalAlignment="Center" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsApplied}"
                                                                 Value="True">
                                                        <Setter Property="Text" Value="Applied"/>
                                                        <Setter Property="Foreground"
                                                                Value="#FF2D9E4A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsApplied}"
                                                                 Value="False">
                                                        <Setter Property="Text"
                                                                Value="Not applied"/>
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Edit button -->
                    <DataGridTemplateColumn Header="" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Edit"
                                        Style="{StaticResource IconButton}"
                                        Command="{Binding DataContext.EditSchemeCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Empty state -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="24"
                Visibility="{Binding SchemeRows.Count,
                    Converter={StaticResource ZeroToVisible}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="No color schemes found in this document."
                           Style="{StaticResource H3}" HorizontalAlignment="Center"/>
                <TextBlock Text="Go to Create to import or build a scheme."
                           Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
